# ============================================================
# VIDHILIKHIT AI PRO — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=production
BASE_URL=https://your-app.onrender.com

# --- WhatsApp Cloud API (Meta) ---
# Get these from: https://developers.facebook.com → Your App → WhatsApp
WHATSAPP_TOKEN=your_whatsapp_permanent_access_token
PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
VERIFY_TOKEN=vidhilikhit_verify_2024_secure

# --- AI Provider (choose one) ---
# Option 1: Google Gemini (FREE — no credit card needed)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: Claude AI by Anthropic (paid, better quality)
# Get from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# AI_PROVIDER=claude

# --- Database ---
# Option 1: PostgreSQL (recommended for Render)
# Render provides this automatically when you add a PostgreSQL database
DATABASE_URL=postgresql://user:password@host:5432/vidhilikhit_db

# Option 2: SQLite (set this to use file-based SQLite instead of PostgreSQL)
# USE_SQLITE=true
# SQLITE_PATH=./data/vidhilikhit.db

# --- Razorpay Payments ---
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# --- Admin ---
ADMIN_PHONE_NUMBER=919876543210
ADMIN_KEY=your_secret_admin_key_change_this

# --- Optional: Logging ---
LOG_LEVEL=info
